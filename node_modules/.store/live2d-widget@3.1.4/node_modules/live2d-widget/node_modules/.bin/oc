#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*) basedir=`cygpath -w "$basedir"`;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="$basedir/D:/zfonlyone/node_modules/.store/opencollective@1.0.3/node_modules"
else
  export NODE_PATH="$NODE_PATH:$basedir/D:/zfonlyone/node_modules/.store/opencollective@1.0.3/node_modules"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../../../../opencollective@1.0.3/node_modules/opencollective/dist/bin/opencollective.js" "$@"
else
  exec node  "$basedir/../../../../../opencollective@1.0.3/node_modules/opencollective/dist/bin/opencollective.js" "$@"
fi
